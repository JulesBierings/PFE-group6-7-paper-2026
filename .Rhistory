)
library(cbsodataR)
library(dplyr)
library(tidyr)
library(sf)
library(knitr)
library(ggplot2)
library(stringr)
if (!dir.exists("data")){
dir.create("data")
}
if (!file.exists("data/raw_dataset.csv")) {
data_download <- cbs_get_data("70072NED")
# Add region label to the dataset
raw_dataset <- data_download %>% cbs_add_label_columns()
raw_dataset <- raw_dataset %>%
mutate(
RegioS_label = str_remove(RegioS_label, " \\(PV\\)")
)
write.csv(raw_dataset, "data/raw_dataset.csv")
}
