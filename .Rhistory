# Installeer en laad de benodigde pakketten
if (!require("tidyverse")) install.packages("tidyverse")
library(tidyverse)
# 1. De directe, openbare URL naar het actuele BBGA CSV-bestand
bbga_csv_url <- "https://onderzoek.amsterdam.nl/sites/default/files/2024-11/bbga_latest_csv.csv"
# 2. Lees het bestand rechtstreeks in (dit kan een paar seconden duren omdat het bestand groot is)
message("Data wordt gedownload...")
bbga_data <- read_csv2(bbga_csv_url) # read_csv2 omdat het een Europees CSV-formaat is (puntkomma)
# Installeer en laad tidyverse indien nodig
if (!require("tidyverse")) install.packages("tidyverse")
library(tidyverse)
# 1. Geef het pad op naar het bestand dat je zojuist hebt gedownload.
# Als het in je huidige R working directory staat, is dit gewoon de bestandsnaam:
bestandspad <- "bbga_latest.csv"
# 2. Lees het bestand gecontroleerd in met read_delim
bbga_data <- read_delim(
file = bestandspad,
delim = ";",           # Velden zijn gescheiden door een puntkomma
escape_double = FALSE,
locale = locale(decimal_mark = ","), # Komma is het decimaal-teken
trim_ws = TRUE
)
