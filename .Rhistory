library(cbsodataR)
library(dplyr)
library(tidyr)
library(sf)
library(knitr)
library(ggplot2)
data_download <- cbs_get_data("70072NED")
# Add region label to the dataset
raw_dataset <- data_download %>% cbs_add_label_columns()
write.csv(raw_dataset, "data/raw_dataset.csv")
# Load saved dataset
raw_dataset = read.csv("data/raw_dataset.csv")
